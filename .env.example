# Postgres connection string. On Railway, add the Postgres plugin and set this
# to a reference to its connection variable (DATABASE_URL).
DATABASE_URL=postgresql://user:password@host:5432/postgres

# The shared mesh code. One secret. Anyone who has it is on the same mesh —
# agents send it as a Bearer token, the website logs in with it.
# Make it long and random, e.g.  openssl rand -hex 16
MESH_CODE=change-me-to-a-long-random-secret
